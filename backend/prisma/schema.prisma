generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  AGENT
}

enum LeadFlowStatus {
  NEW
  WAITING_FOR_DOCUMENTS
  PROCESSING_DOCUMENTS
  QUOTE_READY
  QUOTE_SENT
  QUOTE_ACCEPTED
  WAITING_SIGNATURE
  SIGNED
  WAITING_PAYMENT
  PAYMENT_COMPLETED
  POLICY_ISSUED
  ACTIVE_CUSTOMER
}

enum LeadStatus {
  NEW
  IN_PROGRESS
  DONE
}

enum InterestedIn {
  CARS
  HOME
  BUSINESS
  TRAVEL
  HEALTH
  OTHER
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         Role     @default(AGENT)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  leads     Lead[]
  customers Customer[]

  @@map("users")
}

model Lead {
  id                 String              @id @default(uuid())
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @default(now()) @updatedAt
  leadFlowStatus     LeadFlowStatus      @default(NEW)
  leadStatus         LeadStatus          @default(NEW)
  pdfUrl             String?
  pricingPdfUrl      String?
  leadName           String
  phoneNumber        String
  idNumber           String?
  agentId            String?
  agent              User?               @relation(fields: [agentId], references: [id])
  leadFlowStatusLogs LeadFlowStatusLog[]

  // Person-specific fields
  age                 String?
  dateOfBirth         String?
  cost                String?
  yearOfLicenseIssued String?
  interestedIn        InterestedIn?

  // Insurance quote pricing (generated by the pricing engine on lead creation)
  mandatoryPrice      Float?
  thirdPartyPrice     Float?
  complimentaryPrice  Float?

  // Vehicle info fields (from Israeli gov vehicle API)
  misparRechev        String? // מספר רכב
  tozeretCd           String? // קוד תוצרת
  sugDegem            String? // סוג דגם
  tozeretNm           String? // שם תוצרת
  degemCd             String? // קוד דגם
  shnatYitzur         String? // שנת ייצור
  degemNm             String? // שם דגם
  ramatGimur          String? // רמת גימור
  ramatEivzurBetihuti String? // רמת אבזור בטיחותי
  kvutzatZihum        String? // קבוצת זיהום
  tzevaCd             String? // קוד צבע
  tzevaRechev         String? // צבע רכב
  zmigKidmi           String? // צמיג קדמי
  zmigAhori           String? // צמיג אחורי
  sugDelekNm          String? // סוג דלק
  horaatRishum        String? // הוראת רישום
  moedAliyaLakvish    String? // מועד עליה לכביש
  baalut              String? // בעלות
  misgeret            String? // מספר שילדה
  tozeretEretzNm      String? // ארץ תוצרת
  mishkalKolel        String? // משקל כולל
  nefahManoa          String? // נפח מנוע
  kinuyMishari        String? // כינוי מסחרי
  mivchanAcharonDt    String? // תאריך מבחן אחרון
  tokefDt             String? // תוקף רישוי
  taarichPkikaDt      String? // תאריך פקיעת תוקף
  taarichPkiah        String? // תאריך פקיעת תוקף
  kvuzatAgra          String? // קבוצת אגרה
  mahozMoshav         String? // מחוז מושב
  sugRechevNm         String? // סוג רכב
  degemManoa          String? // קוד מנוע
  koachSus            String? // כוח סוס
  misparDlatot        String? // מספר דלתות
  misparMoshavim      String? // מספר מושבים

  @@map("leads")
}

model LeadFlowStatusLog {
  id         String          @id @default(uuid())
  leadId     String
  lead       Lead            @relation(fields: [leadId], references: [id], onDelete: Cascade)
  fromStatus LeadFlowStatus?
  toStatus   LeadFlowStatus
  changedBy  String?
  note       String?
  createdAt  DateTime        @default(now())

  @@map("lead_flow_status_logs")
}

model Customer {
  id              String   @id @default(uuid())
  createdAt       DateTime @default(now())
  customerName    String
  idNumber        String?
  dateOfBirth     String?
  gender          String?
  insuranceAgent  String?
  agentName       String?
  purchaseType    String?
  uniqueId        String?
  pathNumber      String?
  healthFund      String?
  employer        String?
  signedGoodFaith Boolean  @default(false)
  noFixedAddress  Boolean  @default(false)
  memberId        String?
  workPlace       String?
  carBrand        String?
  agentId         String?
  agent           User?    @relation(fields: [agentId], references: [id])

  contacts Contact[]
  policies Policy[]

  @@map("customers")
}

model Contact {
  id         String @id @default(uuid())
  customerId String
  type       String // e.g., 'mobile', 'phone'
  value      String
  label      String
  icon       String

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("contacts")
}

model Policy {
  id               String    @id @default(uuid())
  customerId       String?
  policyNumber     String
  policyType       String
  insuranceCompany String
  startDate        DateTime?
  endDate          DateTime?
  type             String?
  status           String    @default("Active") // 'Active' or 'Cancelled'

  customer Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("policies")
}
